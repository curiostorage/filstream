# FilStream in-browser Synapse — public settings
#
# Defaults are built into filstream-config.mjs (Filecoin Calibration).
# Override by assigning before ui.mjs loads, e.g. in index.html:
#
#   <script>
#     window.__FILSTREAM_CONFIG__ = {
#       storeRpcUrl: "https://api.calibration.node.glif.io/rpc/v1",
#       storeChainId: 314159,
#       storeProviderId: 9,
#       storeSource: "filstream",
#       storeFilstreamId: "",
#       storeMaxPieceBytes: 133169152,
#     };
#   </script>
#
# If `storeFilstreamId` is left empty, FilStream generates one and persists it in browser
# localStorage so the same dataset can be reused across reloads.
#
# Mapping from legacy Node STORE_* env names:
#   STORE_RPC_URL          -> storeRpcUrl
#   STORE_CHAIN_ID         -> storeChainId
#   STORE_PROVIDER_ID      -> storeProviderId
#   STORE_SOURCE           -> storeSource
#   STORE_FILSTREAM_ID     -> storeFilstreamId  (empty: auto UUID on first upload)
#   STORE_MAX_PIECE_BYTES  -> storeMaxPieceBytes
#
# Not used in the browser (removed with Node store):
#   STORE_HOST, STORE_PORT, STORE_REQUEST_BODY_LIMIT_BYTES
#
