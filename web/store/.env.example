# Store service runtime config
STORE_HOST=127.0.0.1
STORE_PORT=8090

# Synapse / chain (Calibration network)
# Public Calibration RPC (replace if you run your own node/provider endpoint)
STORE_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
# Calibration chain id
STORE_CHAIN_ID=314159
# Your selected provider id
STORE_PROVIDER_ID=9
STORE_SOURCE=filestream
# Session key is provided per upload in POST /api/store/uploads/init

# FilStream dataset key (auto-generated into .env when blank/missing)
STORE_FILSTREAM_ID=

# Limits
STORE_REQUEST_BODY_LIMIT_BYTES=41943040
STORE_MAX_PIECE_BYTES=133169152
